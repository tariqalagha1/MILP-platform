# ============================================================
# MILP Healthcare Revenue Intelligence Platform
# Production Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in the values
# DO NOT commit actual secrets to the repository
# ============================================================

# ===================
# APPLICATION CONFIG
# ===================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ===================
# AUTHENTICATION (Clerk)
# ===================
# Get these from: https://dashboard.clerk.com/ > Your App > API Keys
# Use live keys for production, test keys for development
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
CLERK_SECRET_KEY=sk_live_your_secret_key_here

# Optional: Clerk-specific URLs (defaults usually work)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ===================
# DATABASE (Supabase/Neon/RDS)
# ===================
# Connection string for PostgreSQL
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://postgres.your_ref:your_password@aws-0-region.pooler.supabase.com:6543/postgres

# ===================
# RATE LIMITING (Upstash Redis)
# ===================
# Get these from: https://console.upstash.io/ > Your Database > Details
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_rest_token_here

# ===================
# MONITORING (Sentry)
# ===================
# Get this from: https://sentry.io/ > Your Project > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/123456

# ===================
# OPTIONAL: VERCEL-SPECIFIC
# ===================
# These are automatically set by Vercel during deployment
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_COMMIT_REF=
# VERCEL_URL=
